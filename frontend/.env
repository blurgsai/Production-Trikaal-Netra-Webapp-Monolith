# App backend
VITE_BASE_URL=http://localhost:5000
# VITE_BASE_URL=http://34.60.206.175:5000

# Playback data source: true = real backend (/api/playback/*), else public/ JSON mocks
VITE_USE_REAL_PLAYBACK=true

# GeoServer API
# VITE_GEOSERVER_API_BASE_URL=http://localhost:8000
VITE_GEOSERVER_API_BASE_URL=http://34.60.206.175:8000

# WebSocket base URL
VITE_WS_BASE_URL=ws://34.60.206.175:8765

# Watchkeeper WebSocket Server
# VITE_WATCHKEEPER_WS_BASE_URL=http://34.60.206.175:8003

# GeoServer WMS/WFS/REST base URL (via nginx CORS proxy on port 8090)
VITE_GEOSERVER_BASE_URL=http://34.14.168.111:8090/geoserver

# GeoServer REST API (same proxy, CORS enabled)
VITE_GEOSERVER_REST_URL=http://34.14.168.111:8090/geoserver

# GeoServer workspace
VITE_GEOSERVER_WORKSPACE=trikaalx

# GeoServer REST credentials
VITE_GEOSERVER_USER=admin
VITE_GEOSERVER_PASS=geoserver

# Tileserver
VITE_TILESERVER_URL=http://localhost:8001

# Chatbot
VITE_CHATBOT_BASE_URL=http://localhost:8002