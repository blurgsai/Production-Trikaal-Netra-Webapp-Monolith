# Build stage
FROM node:20-alpine AS build
WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .

# Build-time env vars (Vite bakes these into the bundle)
ARG VITE_BASE_URL=/api
ARG VITE_TILESERVER_URL=/tileserver
ARG VITE_CHATBOT_BASE_URL=/chatbot
ARG VITE_USE_REAL_PLAYBACK=true
ARG VITE_GEOSERVER_API_BASE_URL
ARG VITE_WS_BASE_URL
ARG VITE_GEOSERVER_BASE_URL
ARG VITE_GEOSERVER_REST_URL
ARG VITE_GEOSERVER_WORKSPACE
ARG VITE_GEOSERVER_USER
ARG VITE_GEOSERVER_PASS

ENV VITE_BASE_URL=$VITE_BASE_URL
ENV VITE_TILESERVER_URL=$VITE_TILESERVER_URL
ENV VITE_CHATBOT_BASE_URL=$VITE_CHATBOT_BASE_URL
ENV VITE_USE_REAL_PLAYBACK=$VITE_USE_REAL_PLAYBACK
ENV VITE_GEOSERVER_API_BASE_URL=$VITE_GEOSERVER_API_BASE_URL
ENV VITE_WS_BASE_URL=$VITE_WS_BASE_URL
ENV VITE_GEOSERVER_BASE_URL=$VITE_GEOSERVER_BASE_URL
ENV VITE_GEOSERVER_REST_URL=$VITE_GEOSERVER_REST_URL
ENV VITE_GEOSERVER_WORKSPACE=$VITE_GEOSERVER_WORKSPACE
ENV VITE_GEOSERVER_USER=$VITE_GEOSERVER_USER
ENV VITE_GEOSERVER_PASS=$VITE_GEOSERVER_PASS

RUN npm run build

# Serve with nginx
FROM nginx:stable-alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
