# ClickHouse configuration
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your_clickhouse_password
CLICKHOUSE_HOST=your_clickhouse_host
CLICKHOUSE_PORT=8123

# MongoDB configuration
MONGO_URI=mongodb://user:password@host:port
MONGO_DB=dev

# JWT configuration
JWT_SECRET=your_jwt_secret_key
JWT_ALGORITHM=HS256

# MinIO configuration
MINIO_ENDPOINT=http://host:9100
MINIO_ACCESS_KEY=your_access_key
MINIO_SECRET_KEY=your_secret_key

# GeoServer configuration
GEOSERVER_URL=http://host:8080/geoserver
GEOSERVER_WORKSPACE=workspace
GEOSERVER_USERNAME=admin
GEOSERVER_PASSWORD=your_password

# User activation tokens
USER_ACTIVATION_TOKEN_SECRET=your_token_secret
USER_ACTIVATION_SALT=your_salt
