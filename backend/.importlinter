[importlinter]
root_package = src

[importlinter:contract:router-never-imports-clients]
name = Router never imports from clients
type = forbidden
source_modules =
    src.features.*.router
forbidden_modules =
    src.features.*.clients

[importlinter:contract:clients-never-imports-other-layers]
name = Clients never import from other layers
type = forbidden
source_modules =
    src.features.*.clients
forbidden_modules =
    src.features.*.models
    src.features.*.services
    src.features.*.router

[importlinter:contract:services-never-imports-router]
name = Services never import from router
type = forbidden
source_modules =
    src.features.*.services
forbidden_modules =
    src.features.*.router

[importlinter:contract:shared-only-imports-shared]
name = Shared only imports from shared
type = forbidden
source_modules =
    src.shared
forbidden_modules =
    src.features
