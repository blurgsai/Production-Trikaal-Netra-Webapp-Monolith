# JWT configuration (must match backend JWT_SECRET and JWT_ALGORITHM)
JWT_SECRET=your_jwt_secret_key
JWT_ALGORITHM=HS256

# Tileserver port
TILESERVER_PORT=8001

# Data directory for tileserver metadata DB (basemap records are stored here)
# Tile files (.mbtiles, directories, .sqlite) are managed externally via rsync/SCP
# and registered via POST /basemaps/register with their absolute path
TILESERVER_DATA_DIR=./data
